# Скопируйте в .env и заполните.
#
# Полный Docker:
#   docker compose --env-file .env up -d
#   docker compose -f docker-compose.services.yml --env-file .env up -d
#   docker compose -f docker-compose.frontends.yml --env-file .env build --no-cache && docker compose -f docker-compose.frontends.yml --env-file .env up -d
#
# Локально (infra в Docker, приложения на хосте) — первый compose с merge-файлом:
#   docker compose -f docker-compose.yml -f docker-compose.local.yml --env-file .env up -d
#
# === Важно для VPS ===
# • Внутри Docker сети хосты: postgres, redis, rabbitmq, livekit, minio (имена сервисов из docker-compose.yml).
# • Переменные VITE_* / PUBLIC_* для фронта — только то, что открыто в браузере (HTTPS домен, wss:// к LiveKit).
# • После смены PUBLIC_* или секретов с livekit — пересоберите фронт и синхронизируйте livekit/egress/livekit.yaml keys с LIVEKIT_* в .env.

# ---------- Infra: БД и брокеры ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Публичный URL MinIO для presigned ссылок в ответах API (если за прокси — https://s3.example.com).
MINIO_EXTERNAL_ENDPOINT=https://your-vps.example.com:9000

# ---------- LiveKit (общие для infra egress + всех сервисов) ----------
# Ключи в livekit/livekit.yaml (секция keys: <KEY>: <SECRET>) должны совпадать.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Webhook в gateway: LIVEKIT_WEBHOOK_KEY должен совпадать с webhook.api_key в livekit.yaml (сейчас devkey).
LIVEKIT_WEBHOOK_KEY=devkey

# Публичный IP VPS или 0.0.0.0; при проблемах с WebRTC за NAT укажите внешний IPv4 сервера.
LIVEKIT_NODE_IP=0.0.0.0

# ---------- Backend: JWT и cookie ----------
JWT_SECRET=long-random-string
JWT_ACCESS_TOKEN_EXPIRES=15m
JWT_REFRESH_TOKEN_EXPIRES=7d

COOKIES_SECRET=another-long-random-string
# Для продакшена: .yourdomain.com; локально localhost
COOKIES_DOMAIN=localhost

# Публичный origin API (для логов/Swagger в gateway).
GATEWAY_PUBLIC_ORIGIN=http://localhost:3000
GATEWAY_HTTP_PORT=3000
# Список Origin фронтов (через запятую), с которых браузер ходить будет к API.
HTTP_CORS=http://localhost:5173,http://localhost:5174

# ---------- RabbitMQ: общий exchange и очереди (можно оставить по умолчанию) ----------
RMQ_EVENTS_EXCHANGE=eyenest.events
RMQ_CAMERA_QUEUE=camera.events.queue
RMQ_EVENT_QUEUE=events.queue
RMQ_VIDEO_QUEUE=video.events.queue
RMQ_NOTIFICATIONS_QUEUE=notifications.events.queue
RMQ_GATEWAY_QUEUE=gateway.events.publisher
RMQ_AI_QUEUE=ai.events.queue
MOTION_ON_RK=motion.on
MOTION_OFF_RK=motion.off
MOTION_DETECTED_RK=motion.detected

# ---------- Уведомления ----------
TELEGRAM_BOT_TOKEN=
MAILTRAP_TOKEN=
MOTION_NOTIFICATION_COOLDOWN_SEC=60

# ---------- AI agent ----------
MOTION_AGENT_NAME=motion-detector
MOTION_MIN_AREA=2500
MOTION_FRAME_COOLDOWN_SEC=3.0
MOTION_BLUR_SIZE=21

# ---------- Video / egress вспомогательные ----------
PRESIGNED_URL_EXPIRES_IN=3600
EGRESS_TEMPLATE_URL=http://localhost:8080

# ---------- Фронтенды (сборка): URL для браузера пользователя ----------
# HTTPS/WSS на проде обязательны за обратным прокси.
PUBLIC_API_URL=http://localhost:3000
PUBLIC_LIVEKIT_WS_URL=ws://localhost:7880
FRONTEND_HTTP_PORT=5173
CAMERA_FRONTEND_HTTP_PORT=5174
