# Скопируйте: cp .env.example .env
# Запуск: из каталога eyenest-infra → docker compose -f compose.yaml --env-file .env up -d --build
#
# Раскладка: рядом с eyenest-infra лежат eyenest-services, eyenest-viewer-frontend, eyenest-camera-frontend
# (значения по умолчанию в compose уже такие). Иначе задайте пути относительно eyenest-infra:
# EYENEST_SERVICES_DIR=../eyenest-services
# EYENEST_VIEWER_FRONTEND_DIR=../eyenest-viewer-frontend
# EYENEST_CAMERA_FRONTEND_DIR=../eyenest-camera-frontend
# Монорепо с папками services/, frontend/, camera-frontend/:
# EYENEST_SERVICES_DIR=../services
# EYENEST_VIEWER_FRONTEND_DIR=../frontend
# EYENEST_CAMERA_FRONTEND_DIR=../camera-frontend
#
# PUBLIC_HOST — IPv4 или DNS сервера, с которого пользователи заходят в браузере (без https:// и без порта).
# Должен совпадать с адресом в URL: иначе Caddy (tls internal) выпускает сертификат на «чужой» хост — SSL_ERROR_INTERNAL_ERROR_ALERT.

PUBLIC_HOST=127.0.0.1

EYENEST_SERVICES_DIR=../eyenest-services
EYENEST_VIEWER_FRONTEND_DIR=../eyenest-viewer-frontend
EYENEST_CAMERA_FRONTEND_DIR=../eyenest-camera-frontend

POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=postgres

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WEBHOOK_KEY=devkey

JWT_SECRET=secret_key
JWT_ACCESS_TOKEN_EXPIRES=15m
JWT_REFRESH_TOKEN_EXPIRES=10d

COOKIES_SECRET=secret
# Оставьте пустым за Caddy (host-only cookies). Иначе домен вида .example.com
COOKIES_DOMAIN=

TELEGRAM_BOT_TOKEN=
MAILTRAP_TOKEN=
MOTION_NOTIFICATION_COOLDOWN_SEC=60

RMQ_EVENTS_EXCHANGE=eyenest.events
RMQ_CAMERA_QUEUE=camera.events.queue
RMQ_EVENT_QUEUE=events.queue
RMQ_VIDEO_QUEUE=video.events.queue
RMQ_NOTIFICATIONS_QUEUE=notifications.events.queue
RMQ_GATEWAY_QUEUE=gateway.events.publisher
RMQ_AI_QUEUE=ai.events.queue
MOTION_ON_RK=motion.on
MOTION_OFF_RK=motion.off
MOTION_DETECTED_RK=motion.detected

MOTION_AGENT_NAME=motion-detector
MOTION_MIN_AREA=2500
MOTION_FRAME_COOLDOWN_SEC=3.0
MOTION_BLUR_SIZE=21

PRESIGNED_URL_EXPIRES_IN=3600
EGRESS_TEMPLATE_URL=https://eyenest-egress-layout.vercel.app

GATEWAY_HTTP_PORT=3000

# Опционально, если отдельно от PUBLIC_HOST:
# LIVEKIT_NODE_IP=

FRONTEND_HTTP_PORT=5173
CAMERA_FRONTEND_HTTP_PORT=5174
