{
	servers {
		protocols h1 h2 h3
	}
}

:80 {
	redir https://{host}{uri}
}

# tls internal — без покупки домена; браузер спросит доверие к локальному CA Caddy (один раз «Дополнительно → перейти»).
#
# Нельзя оставлять только https://:443 — при заходе по IP/127.0.0.1 SNI не совпадает с выпущенным сертификатом, TLS падает
# с alert internal error (curl: error:0A000438). Нужны явные хосты; PUBLIC_HOST задаётся в .env и в контейнере caddy.

https://{$PUBLIC_HOST}, https://127.0.0.1, https://localhost {
	tls internal

	handle_path /cam/* {
		reverse_proxy camera-frontend:80
	}

	handle /openapi.yaml {
		reverse_proxy gateway-service:3000
	}
	handle /docs* {
		reverse_proxy gateway-service:3000
	}
	handle /auth* {
		reverse_proxy gateway-service:3000
	}
	handle /camera* {
		reverse_proxy gateway-service:3000
	}
	handle /video* {
		reverse_proxy gateway-service:3000
	}
	handle /notifications* {
		reverse_proxy gateway-service:3000
	}
	handle /events* {
		reverse_proxy gateway-service:3000
	}
	handle /live_kit* {
		reverse_proxy gateway-service:3000
	}
	handle /health {
		reverse_proxy gateway-service:3000
	}

	handle {
		reverse_proxy frontend:80
	}
}

https://{$PUBLIC_HOST}:7443, https://127.0.0.1:7443, https://localhost:7443 {
	tls internal
	reverse_proxy livekit:7880
}

https://{$PUBLIC_HOST}:8900, https://127.0.0.1:8900, https://localhost:8900 {
	tls internal
	reverse_proxy minio:9000
}
